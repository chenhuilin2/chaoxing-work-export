        <div class="het72"></div>
    </div>
</div>

<script>

    function proceduralCodePreview(questionId) {
        var editor = codeEditors[questionId];
        var pureTxt = editor.getValue();
        var code = pureTxt;
        code = UE.utils.html(code);
        if(top && top.previewHtmlPage){
            top.previewHtmlPage(code);
        }else if(parent && parent.parent && parent.parent.parent && parent.parent.parent.previewHtmlPage){
            parent.parent.parent.previewHtmlPage(code);
        }else {
            previewHtmlPage(code);
        }
    }

    function previewHtmlPage(code) {
        var renderTarget = document.querySelector('.preview-render-div');
        if (!renderTarget) {
            return;
        }
        renderTarget.innerHTML = '';

        var iframe = document.createElement('iframe');
        iframe.setAttribute('sandbox', 'allow-scripts');
        iframe.style.width = '100%';
        iframe.style.height = '600px';
        iframe.style.border = 'none';
        iframe.style.borderRadius = '8px';
        iframe.style.background = 'white';
        iframe.style.display = 'block';

        iframe.srcdoc =
                '<meta ' +
                'http-equiv="Content-Security-Policy" ' +
                'content="' +
                'default-src \'none\'; ' +
                'script-src \'unsafe-inline\'; ' +
                'style-src \'unsafe-inline\'; ' +
                'img-src data:; ' +
                'connect-src \'none\'; ' +
                'frame-src \'none\'; ' +
                'object-src \'none\'; ' +
                'form-action \'none\';' +
                '"/>' +
                '<script>' +
                'window.alert=function(){};' +
                'window.confirm=function(){return false;};' +
                'window.prompt=function(){return null;};' +
                'window.open=function(){return null;};' +
                '</scr' + 'ipt>' +
                code;
        renderTarget.appendChild(iframe);
        var previewDialog = renderTarget.closest('.preview-dialog');
        if (previewDialog) {
            previewDialog.style.display = 'block';
        }
    }

    function closeHtmlPage() {
        $('.preview-dialog').hide();
    }
</script><!-- 代码高亮开始 start -->
