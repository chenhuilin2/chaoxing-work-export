<div id="aiAssistantId"></div>
<script type="text/javascript" src="//mooc1.chaoxing.com/mooc-ans/js/ServerHost.js"></script>
<script type="text/javascript" src="//mooc1.chaoxing.com/mooc-ans/mooc2/js/html2canvas.min.js"></script>
<script type="text/javascript" async src="https://stat2-ans.chaoxing.com/stat2/js/cozebot-sdk.min.js"></script>
<script type="text/javascript">
    //0作业 1 考试 2 测验 3 自测
    function initAssistant(exampleId, questionType, typeName, questionId, questionTypeId, taskType, taskId) {
        var courseId = "244670737";
        var classId = "102842771";
        var cpi = "408105850";

        var sourceObj = {
            "serverName": "mooc1",
            "businessTag": "question_assistant",
            "extraData": {
                "courseId": courseId,
                "clazzId": classId,
                "personId": cpi,
                "relationType": taskType,
                "relationId": taskId,
                "questionType": questionType,
                "questionTypeId": questionTypeId,
                "questionId": questionId
            }
        };
        var sourceInfo = JSON.stringify(sourceObj);
        sourceInfo = encodeURIComponent(sourceInfo);

        var text = getPlainText(exampleId, questionType);
        if (text.length > 0) {
            postTextMsg(text, sourceInfo);
            return;
        }

        loadImgData(exampleId, sourceInfo);
    }

    function loadImgData(exampleId, sourceInfo) {
        $.toast({type: "loading", time: 0, content: "生成提问中..."});

        var tempDiv = cloneOriginDiv(exampleId);
        $("#" + exampleId).append(tempDiv);

        processImagesInDiv(tempDiv).then(() => convertDivToImage(tempDiv)).then((data) => {
            var imgData = data.toDataURL("image/png", 0.9);
            showAssistant(imgData, sourceInfo);
            tempDiv.remove();
            $("#dialogToast").remove();
        }).catch((error) => {
            console.error("处理图片或转换为图片时出错:", error);
            $.toast({type: "failure", content: "处理图片或转换图片出错，请稍后重试"});
            tempDiv.remove();
            $("#dialogToast").remove();
        });
    }

    function cloneOriginDiv(id) {
        var originDiv = $("#" + id).find(".aiAreaContent")[0];
        return originDiv.cloneNode(true);
    }

    function processImagesInDiv(tempDiv) {
        var imgPromises = [];
        $(tempDiv).find("img").each(function (idx, ele) {
            var url = ele.src || "";
            var starType = url.includes("/star3/") ? "star3" : url.includes("/star4/") ? "star4" : null;
            if (!starType) {
                return true;
            }

            var arr = url.split(starType);
            if (arr.length < 2) {
                return true;
            }
            url = location.protocol + "//" + location.hostname + "/p-ans/" + starType + arr[1];

            var imgPromise = new Promise((resolve, reject) => {
                var newImg = new Image();
                newImg.onload = () => {
                    ele.src = url;
                    resolve();
                };
                newImg.onerror = reject;
                newImg.src = url;
            });
            imgPromises.push(imgPromise);
        });

        return Promise.all(imgPromises);
    }

    function convertDivToImage(tempDiv) {
        return html2canvas(tempDiv, {
            ignoreElements: function (element) {
                return element.classList.contains("element-invisible-hidden");
            }
        });
    }

    function showAssistant(imgData, sourceInfo) {
        try {
            CozeBotSDK.init({
                appId: "1192651262850",
                botId: "7429626930406326309",
                rootElementId: "aiAssistantId",
                upload: true,
                target: 'https://stat2-ans.chaoxing.com',
                sourceInfo: sourceInfo
            });

            CozeBotSDK.sendToIframeMessage({
                eventName: "callCozeConversation",
                isLastWindow: true
            });

            setTimeout(function () {
                CozeBotSDK.sendToIframeImageBase64({
                    eventName: "sendImgFile",
                    imageBase64: imgData,
                    presetMsg: "讲解一下这道题",
                    model: 1
                });
            }, 1000);
        } catch (e) {
            console.error("Error in CozeBotSDK:", e);
        }
    }

    function postTextMsg(text, sourceInfo) {
        try {
            CozeBotSDK.init({
                appId: "1192651262850",
                botId: "7429626930406326309",
                rootElementId: "aiAssistantId",
                upload: true,
                target: 'https://stat2-ans.chaoxing.com',
                sourceInfo: sourceInfo
            });

            CozeBotSDK.sendToIframeMessage({
                eventName: "callCozeConversation",
                isLastWindow: true
            });

            setTimeout(function () {
                CozeBotSDK.sendToIframeMessage({
                    eventName: "sendMsgCozeConversation",
                    msg: text,
                    model: 1
                });
            }, 1000);
        } catch (e) {
            console.error("Error in CozeBotSDK:", e);
        }
    }

    function getPlainText(id, questionType) {
        var source = $("#" + id);
        var contnt = source.find(".qtContent");
        if (contnt.find("img, iframe").length > 0) {
            return "";
        }
        var html = "讲解一下这道题：\n" + "\#\#\# 题目：\n" + contnt.text() + "\n";

        var detail = source.find(".qtDetail");
        if (detail.find("img, iframe").length > 0) {
            return "";
        }
        if (questionType == 11 || questionType == 14) {
            detail.find("dt, dd").each(function () {
                var option = $(this).text();
                html += option + "\n";
            });
        } else if (questionType == 20) {
            detail.each(function () {
                var option = $(this).text();
                html += option + "\n";
            });
        } else {
            detail.find("li").each(function () {
                var option = $(this).text();
                html += option + "\n";
            });
        }

        var studentAnswer = source.find(".stuAnswerContent");
        if (studentAnswer.find("img, iframe").length > 0) {
            return "";
        }
        if (studentAnswer.length > 0) {
            html += "\#\#\# 我的答案：\n";
        }
        studentAnswer.each(function () {
            if (questionType == 17) {
                var answer = $(this).html();
                var htmlContent = $(answer);
                htmlContent.children("*").each(function () {
                    var text = $(this).text().trim();
                    if (text) {
                        html += text + "\n";
                    }
                });
            } else {
                var option = $(this).text();
                html += option + "\n";
            }
        });

        var rightAnswer = source.find(".rightAnswerContent");
        if (rightAnswer.find("img, iframe").length > 0) {
            return "";
        }
        if (rightAnswer.length > 0) {
            html += "\#\#\# 正确答案：\n";
        }
        rightAnswer.each(function () {
            var option = $(this).text();
            html += option + "\n";
        });

        var analysis = source.find(".qtAnalysis");
        if (analysis.find("img, iframe").length > 0) {
            return "";
        }
        if (analysis.length > 0 && analysis.text().trim().length > 0) {
            html += "\#\#\# 答案解析：\n" + analysis.text() + "\n";
        }

        return html;
    }
</script><link rel="stylesheet" type="text/css" href="//mooc1.chaoxing.com/mooc-ans/mooc2/css/prompt.css?v=2023-0711-1500"/>
