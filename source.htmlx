							<div class="marBom60 questionLi singleQuesId" style="word-wrap: break-word;" id="question404312884" data="404312884" tabindex="0" aria-label="题目详情">
								<div class="aiArea">
								<div class="aiAreaContent">
																	<h3 class="mark_name colorDeep" tabindex="0">33. <span class="colorShallow">(简答题, 10分)</span><span class="qtContent workTextWrap"><p>请写出求n!(n为奇数)的递归程序(可以用C语言写，也可以用课本中的define语言来表达)</p></span></h3>
								
																	<div class="mark_answer" tabindex="0">
										<div class="mark_answer_key pad0">
											<dl class="mark_fill colorDeep" id="qb404312884">
												<dt class="positionStyle"><i class="fontWeight custom-style">我的答案：</i>
													<div class="mark_score">
																												<div class="totalScore fr">
															<i class="custom-style">8</i>分														</div>
																											</div>
												</dt>

																																				
												<dd class="textwrap stuAnswerContent reserve-newline"><p>int a (int n){</p><p>&nbsp;&nbsp;&nbsp;&nbsp;if( n==1)</p><p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;return 1;</p><p>&nbsp;&nbsp;&nbsp;&nbsp;else <br/></p><p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;return n*a(n-1);<br/></p><p>}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;//函数<br/></p></dd>
											</dl>
																						<dl class="mark_fill colorGreen">
												<dt><i class="fontWeight custom-style"> 正确答案：</i></dt>
																								<dd class="rightAnswerContent workTextWrap"><p>无</p></dd>
																							</dl>
																					</div>
																				<!--显示知识点-->
        <div class="knowledgePointBx colorGray">
        <span class="answerFont fl" style="line-height: 30px;">知识点：</span>
        <div class="fl answerCon">
            <ul class="knowledgeList">
                                    <li  topicid="96314759"  title="">
                        <a  target="_blank" href="https://mooc2-ans.chaoxing.com/mooc2-ans/mycourse/stu?courseid=244670737&clazzid=102842771&cpi=408105850&microTopicId=96314759&&enc=b25dd9753514939899fc790be83beaee&t=1781812287162" >递归基础与递归公式</a>
                    </li>
                            </ul>
        </div>
        <p class="clear"></p>
    </div>
    <!--显示知识点-->									</div>

									
																		
